  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "1. Info do Sistema (Público)",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8080/info", "host": ["localhost"], "port": "8080", "path": ["info"] }
          }
        },
        {
          "name": "2. Login MASTER",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8080/auth/login", "host": ["localhost"], "port": "8080", "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"master\",\n  \"password\": \"master123\"\n}" }
          }
        },
        {
          "name": "3. Login CONTRIBUTOR",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8080/auth/login", "host": ["localhost"], "port": "8080", "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"contributor\",\n  \"password\": \"contributor123\"\n}" }
          }
        },
        {
          "name": "4. Login AUDITOR",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8080/auth/login", "host": ["localhost"], "port": "8080", "path": ["auth", "login"] },
