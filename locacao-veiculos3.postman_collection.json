          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:8080/auth/registro", "host": ["localhost"], "port": "8080", "path": ["auth", "registro"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"novoauditor\",\n  \"password\": \"senha123\",\n  \"role\": \"ROLE_AUDITOR\"\n}" }
          }
        }
      ]
